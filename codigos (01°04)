Algoritmo "Aposentadoria"
var
   idade,t_servico:inteiro
inicio
   escreval("para se aposentar vc precisa apresentar ao menos um desses requisitos")
   escreval("ter pelo menos 65 anos")
   escreval("ter pelo menos 60 anos e 25 de tempo de serviço")
   escreval("ter 30 anos de serviço")
   escreval("qual sua idade senhor?")
   leia(idade)
   escreval("quantos anos o senhor trabalhou?")
   leia (t_servico)

   se (idade>=65) ou (idade>=60) e (t_servico>=25) ou (t_servico>=30)entao
      escreval("requerir aposentadoria")
   senao
      escreval("nao requerir aposentadoria")
   fimse
fimalgoritmo
